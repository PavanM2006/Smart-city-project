# Node Environment Mode
PORT=5000
NODE_ENV=development

# Secure CORS allowed origin
FRONTEND_URL=http://localhost:5173

# MySQL Database Configurations
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_root_password
DB_NAME=smartcity_db

# JSON Web Token Config
JWT_SECRET=your_super_secret_jwt_key_2026
JWT_EXPIRES_IN=24h

# Nodemailer SMTP Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_address@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Smart City Portal <no-reply@smartcity.gov>"

# Firebase Cloud Messaging Service Account (JSON credential fields)
FIREBASE_PROJECT_ID=smartcity-fcm-project
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@smartcity-fcm.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour_FCM_Service_Account_Private_Key_Here\n-----END PRIVATE KEY-----"
